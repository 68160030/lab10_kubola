public class END {
    String firstname;
    String lastname;
    int age;

    public END(String fn, String ln) {
        firstname = fn;
        lastname = ln;
    }

    public END(String fn, String ln, int a) {
        this(fn,ln);
        age = a;
    }

    public void show() {
        System.out.println("Name : " + firstname + " " + lastname + " Age : " + age);
    }
}
