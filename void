public class ORE2 {
    int base;
    int height;
    ORE2() {
        base = 1;
        height = 1;
    }
    ORE2(int b, int h) {
        base = b;
        height = h;
    }
    double area() {
        return 1.0 / 2 * base * height;
    }
    void display() {
        System.out.println("Triangle: ");
        System.out.println("Base: " + base + " Height: " + height);
        System.out.println("Area =  " + area());
    }
}
